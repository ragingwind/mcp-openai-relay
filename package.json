{
  "name": "mcp-openai-relay",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:vercel": "vercel dev",
    "build": "OPENAI_API_KEY=\"${OPENAI_API_KEY:-build-dummy}\" RELAY_AUTH_TOKEN=\"${RELAY_AUTH_TOKEN:-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx}\" next build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:integration": "vitest run --project integration --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "mcp-handler": "^1.1.0",
    "next": "^16.2.4",
    "openai": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.14",
    "msw": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
