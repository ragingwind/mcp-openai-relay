# OpenAI API key. Sensitive — register separately for Production/Preview in Vercel dashboard.
OPENAI_API_KEY=

# OpenAI-compatible base URL. Optional. Default: SDK built-in (https://api.openai.com/v1).
# Set to point at Azure OpenAI, a self-hosted vLLM/Ollama gateway, or a local mock.
OPENAI_BASE_URL=

# Bearer token sent by the MCP host. Sensitive — generate as 32+ random bytes.
RELAY_AUTH_TOKEN=

# Integer ceiling that overrides caller's max_tokens when exceeded. Default: 4096
MAX_OUTPUT_TOKENS_CEILING=

# Integer milliseconds for OpenAI request timeout. Default: 60000
REQUEST_TIMEOUT_MS=

# --- Script-only (not consumed by the server) ---

# Default tool name used by `pnpm inspect` for tools/call. Default: completion_chat.
# Override with `--tool=...` per-call.
MCP_TOOL=

# Default model used by `pnpm inspect` (scripts/mcp-inspect.mjs). Default: gpt-4o-mini.
# Override with `--model=...` per-call.
MCP_MODEL=

# Default user message used by `pnpm inspect` for tools/call. Default: ping.
# Override with `--message=...` per-call.
MCP_MESSAGE=

# Default MCP endpoint URL used by `pnpm inspect` and `pnpm verify`.
# Default: http://localhost:3000/api/mcp. Override with `--url=...`.
MCP_URL=

# Default model used by `pnpm verify` (scripts/verify.mjs). Default: gpt-4o-mini.
# Note: separate from MCP_MODEL — verify.mjs reads VERIFY_MODEL only.
VERIFY_MODEL=
